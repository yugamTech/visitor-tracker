    "bcryptjs": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3",
    "drizzle-orm": "^0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta",
    "next-themes": "^0.4.6",
    "postgres": "^3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7",
